{
  "name": "mellow-photos-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/ensure-index-html.mjs",
    "dev": "vite --host 127.0.0.1 --port 4173",
    "prebuild": "node scripts/ensure-index-html.mjs",
    "build": "node scripts/ensure-index-html.mjs && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "node --test",
    "test:e2e": "playwright test --config=playwright.config.mjs",
    "sync:unsplash": "python3 scripts/unsplash_sync.py --username mihmihfoto --count 32 --proxy-base http://127.0.0.1:8787 --clean",
    "optimize:images": "python3 scripts/optimize_images.py"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "vite": "^7.1.0"
  }
}
